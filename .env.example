# === Supabase (obrigatório para todos) ===
SUPABASE_URL=seu_supabase_url
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# === Hablla ===
HABLLA_TOKEN=seu_token_ou_deixe_vazio_para_login
HABLLA_EMAIL=seu_email_hablla
HABLLA_PASSWORD=sua_senha_hablla
HABLLA_WORKSPACE_ID=id_do_workspace
HABLLA_BOARD_ID=id_do_board
HABLLA_CARDS_DAYS=7
HABLLA_CARDS_MAX_PAGES=500

# === SIGE ===
SIGE_TOKEN=seu_token_sige
SIGE_USER=seu_usuario_sige
SIGE_APP=sua_app_sige

# === Zenvia ===
ZENVIA_ACCESS_TOKEN=seu_token_zenvia
ZENVIA_REQUEST_DELAY_MS=1000

# === Zoho ===
ZOHO_CLIENT_ID=seu_client_id
ZOHO_CLIENT_SECRET=seu_client_secret
ZOHO_REFRESH_TOKEN=seu_refresh_token
ZOHO_ACCOUNT_OWNER=seu_account_owner

# Zoho Leads (contact_site)
ZOHO_LEADS_APP_NAME=nome_do_app
ZOHO_LEADS_REPORT_NAME=nome_do_reporte

# Zoho Scheduling (events_agendamento)
ZOHO_SCHEDULING_APP_NAME=nome_do_app
ZOHO_SCHEDULING_REPORT_NAME=nome_do_reporte
