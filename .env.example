# Copie para .env e preencha localmente. Nunca versione valores reais.

# Google Sheets (service account)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_READ_TIMEOUT_MS=180000
GOOGLE_SHEETS_READ_MAX_ATTEMPTS=5
GOOGLE_SHEETS_STAGING_CHUNK_ROWS=500
GOOGLE_SHEETS_STAGING_CHUNK_BYTES=1500000
GOOGLE_SHEETS_STAGING_CHUNK_INTERVAL_MS=1250
GOOGLE_SHEETS_PROMOTION_MAX_BYTES=1500000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BATCH_SIZE=500
SUPABASE_MAX_ATTEMPTS=4

# Hablla
HABLLA_TOKEN=
HABLLA_EMAIL=
HABLLA_PASSWORD=
HABLLA_WORKSPACE_ID=
HABLLA_BOARD_ID=
HABLLA_SPREADSHEET_ID=
HABLLA_CARDS_DAYS=7
HABLLA_CARDS_MAX_PAGES=2000
HABLLA_CARDS_PAGES_WITHOUT_RECENT_CREATED=2
# O modo normal conserva o corte rapido historico. Use exhaustive=true apenas
# em recuperacoes locais: ele valida updated_at desc ate uma fronteira segura.
HABLLA_CARDS_EXHAUSTIVE=false
HABLLA_CARDS_CRAWL_PASSES=1
HABLLA_CARDS_CRAWL_ATTEMPTS=1
HABLLA_CARDS_PRESERVE_UNFETCHED=true
# Permite executar somente cards numa recuperacao sem tocar nas outras abas.
HABLLA_SHEETS_DATASETS=cards,attendants,clients
HABLLA_SHEETS_ATTENDANTS_DAYS=1
HABLLA_SHEETS_CLIENTS_DAYS=1
HABLLA_SHEETS_ALLOW_EMPTY_REPLACEMENT=false
HABLLA_CLIENTS_MAX_PAGES=150
HABLLA_ATTENDANTS_DAYS=5
HABLLA_MIN_INTERVAL_MS=500
HABLLA_REQUEST_TIMEOUT_MS=60000
HABLLA_MAX_ATTEMPTS=5

# Orquestrador das planilhas. O padrão 1 evita repetir uma escrita inteira.
SYNC_SCRIPT_MAX_ATTEMPTS=1

# SIGE
SIGE_TOKEN=
SIGE_USER=
SIGE_APP=
SIGE_SPREADSHEET_ID=
SIGE_MIN_INTERVAL_MS=500
SIGE_MAX_RECORDS_PER_DAY=50000
SIGE_SHEETS_DAYS=5
SIGE_SHEETS_START_DATE=
SIGE_SHEETS_END_DATE=
SIGE_SHEETS_ALLOW_EMPTY_REPLACEMENT=false

# Zenvia
ZENVIA_ACCESS_TOKEN=
ZENVIA_QUEUE_ID=
ZENVIA_REQUEST_DELAY_MS=1000
ZENVIA_SPREADSHEET_ID=
ZENVIA_SHEET_NAME=
ZENVIA_SHEETS_DAYS=1
ZENVIA_SHEETS_START_DATE=
ZENVIA_SHEETS_END_DATE=
ZENVIA_SHEETS_ALLOW_EMPTY_REPLACEMENT=false

# Zoho OAuth
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNT_OWNER=
ZOHO_MAX_PAGES=10000

# Zoho Leads
ZOHO_LEADS_APP_NAME=
ZOHO_LEADS_REPORT_NAME=
ZOHO_LEADS_COLUMN_MAPPING=
ZOHO_LEADS_SPREADSHEET_ID=
ZOHO_LEADS_SHEET_NAME=
ZOHO_LEADS_SHEETS_DAYS=1
ZOHO_LEADS_SHEETS_START_DATE=
ZOHO_LEADS_SHEETS_END_DATE=
ZOHO_LEADS_SHEETS_ALLOW_EMPTY_REPLACEMENT=false

# Zoho Scheduling
ZOHO_SCHEDULING_APP_NAME=
ZOHO_SCHEDULING_REPORT_NAME=
ZOHO_SCHEDULING_COLUMN_MAPPING=
ZOHO_SCHEDULING_SPREADSHEET_ID=
ZOHO_SCHEDULING_SHEET_NAME=
# Sem configuracao, preserva o intervalo historico (mes anterior ate hoje).
ZOHO_SCHEDULING_SHEETS_DAYS=
ZOHO_SCHEDULING_SHEETS_START_DATE=
ZOHO_SCHEDULING_SHEETS_END_DATE=
ZOHO_SCHEDULING_SHEETS_ALLOW_EMPTY_REPLACEMENT=false
